---
interface Props {
    tag: string;
    link: string;
}

const { tag, link } = Astro.props;
---

<a
    class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-200 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-700 shadow-sm dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-200"
    href={link}
    target="_blank"
    rel="noreferrer"
>
    <span class="h-1.5 w-1.5 rounded-full bg-slate-500 dark:bg-slate-400"
    ></span>
    {tag}
</a>
