---
import TechStackPills from "../components/TechStackPills.astro";
import "../styles/global.css";

const apiBaseUrl =
  import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8000";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Validador Lingüístico Inteligente</title>
    <meta
      name="description"
      content="Valida palabras en español con analisis NLP, lema, POS y una decision basada en IA."
    />
    <script is:inline>
      (() => {
        const storageKey = "theme-preference";
        const root = document.documentElement;

        try {
          const storedTheme = localStorage.getItem(storageKey);
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const useDark = storedTheme ? storedTheme === "dark" : prefersDark;

          root.classList.toggle("dark", useDark);
          root.style.colorScheme = useDark ? "dark" : "light";
        } catch {
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          root.classList.toggle("dark", prefersDark);
          root.style.colorScheme = prefersDark ? "dark" : "light";
        }
      })();
    </script>
  </head>
  <body class="antialiased text-slate-900 dark:text-slate-100">
    <main
      class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-4 py-10"
    >
      <section class="grid w-full gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="flex flex-col justify-center gap-3">
          <div class="flex flex-wrap items-center gap-2 *:text-nowrap">
            <div
              class="inline-flex w-fit items-center gap-2 rounded-full border border-teal-200 bg-white/80 px-4 py-2 text-sm font-medium text-teal-900 shadow-sm dark:border-teal-700/60 dark:bg-slate-900/70 dark:text-teal-200"
            >
              <span class="h-2 w-2 rounded-full bg-teal-600"></span>
              NLP + IA para español
            </div>
            <TechStackPills
              tag="FastAPI"
              link="https://fastapi.tiangolo.com/"
            />
            <TechStackPills
              tag="spaCy"
              link="https://spacy.io/models/es#es_core_news_lg"
            />
            <TechStackPills tag="Astro" link="https://astro.build/" />
            <TechStackPills
              tag="Tailwind CSS"
              link="https://tailwindcss.com/"
            />
          </div>
          <div>
            <h1
              class="max-w-xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-[2.7rem] xl:text-5xl mb-3 transition-all duration-300 dark:text-slate-100"
            >
              Validador Lingüístico con IA
            </h1>
            <p
              class="max-w-2xl text-lg text-slate-600 mb-1.5 dark:text-slate-300"
            >
              Introduce una palabra y la IA comprobará si es válida en español.
            </p>
            <p class="max-w-2xl text-xs text-slate-400 dark:text-slate-500">
              Nota: La IA puede cometer errores.
            </p>
            <button
              id="theme-toggle"
              type="button"
              class="cursor-pointer mt-4 inline-flex w-fit items-center gap-2 rounded-md border border-slate-300 bg-transparent px-2.5 py-1 text-xs font-medium text-slate-600 transition hover:border-slate-400 hover:text-slate-900 dark:border-slate-600 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:text-white"
              aria-label="Cambiar tema"
            >
              <span id="theme-toggle-label">Tema: claro</span>
            </button>
          </div>
        </div>

        <div
          class="my-auto h-fit rounded-4xl border border-white/80 bg-white/92 shadow-xl shadow-teal-950/5 p-6 dark:border-slate-700/70 dark:bg-slate-900/85 dark:shadow-black/30"
        >
          <form id="validator-form" class="space-y-4">
            <label
              for="term"
              class="block text-sm font-semibold text-slate-700 dark:text-slate-200"
              >Introduce una palabra:</label
            >
            <div class="flex gap-3 flex-row">
              <input
                id="term"
                name="term"
                type="text"
                minlength="3"
                maxlength="25"
                inputmode="text"
                autocomplete="off"
                placeholder="corriendo"
                class="flex-1 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-2 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-teal-500 focus:bg-white focus:ring-4 focus:ring-teal-100 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-teal-400 dark:focus:bg-slate-900 dark:focus:ring-teal-900/40"
              />
              <button
                id="submit-btn"
                type="submit"
                class="cursor-pointer inline-flex items-center justify-center rounded-2xl bg-slate-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-700 disabled:cursor-not-allowed disabled:opacity-60 dark:bg-teal-600 dark:hover:bg-teal-500"
              >
                Validar
              </button>
            </div>
          </form>

          <section
            id="result"
            class="mt-6 hidden rounded-3xl bg-slate-50 p-5 ring-1 ring-slate-200 dark:bg-slate-800/80 dark:ring-slate-700"
          >
            <div>
              <p
                id="result-message"
                class="text-base font-medium text-slate-700"
              >
              </p>
            </div>
            <a
              id="rae-link"
              href="#"
              target="_blank"
              rel="noreferrer"
              class="hidden items-center gap-2 text-sm font-semibold text-teal-800 hover:text-teal-950 dark:text-teal-300 dark:hover:text-teal-200"
            ></a>
          </section>
        </div>
      </section>
    </main>

    <p
      class="fixed bottom-3 left-1/2 z-10 -translate-x-1/2 text-[11px] font-medium tracking-wide text-slate-400/80 dark:text-slate-500/80"
    >
      Created by
      <span class="font-bold">AI</span>
      driven by <a
        href="https://github.com/Sergio-D-Vico-Pineda"
        target="_blank"
        rel="noreferrer"
        class="text-teal-800 hover:text-teal-950 dark:text-teal-600 dark:hover:text-teal-500 cursor-pointer"
        >Scarpy</a
      >
    </p>

    <script is:inline type="module" define:vars={{ apiBaseUrl }}>
      const apiBaseUrlValue = apiBaseUrl;
      const form = document.getElementById("validator-form");
      const submitBtn = document.getElementById("submit-btn");
      const input = document.getElementById("term");
      const result = document.getElementById("result");
      const resultMessage = document.getElementById("result-message");
      const raeLink = document.getElementById("rae-link");
      const themeToggle = document.getElementById("theme-toggle");
      const themeToggleLabel = document.getElementById("theme-toggle-label");

      let isLoading = false;
      const THEME_STORAGE_KEY = "theme-preference";

      function applyTheme(theme) {
        const isDark = theme === "dark";
        document.documentElement.classList.toggle("dark", isDark);
        document.documentElement.style.colorScheme = isDark ? "dark" : "light";
        if (themeToggleLabel) {
          themeToggleLabel.textContent = isDark
            ? "Tema: oscuro"
            : "Tema: claro";
        }
      }

      if (themeToggle) {
        applyTheme(
          document.documentElement.classList.contains("dark")
            ? "dark"
            : "light",
        );
        themeToggle.addEventListener("click", () => {
          const isDark = document.documentElement.classList.contains("dark");
          const nextTheme = isDark ? "light" : "dark";
          applyTheme(nextTheme);
          try {
            localStorage.setItem(THEME_STORAGE_KEY, nextTheme);
          } catch {
            // Ignore storage errors in restricted environments.
          }
        });
      }

      // Pattern matching backend validation: only a-z, áéíóúü, and ñ
      const ALLOWED_PATTERN = /^[a-záéíóúüñ]+$/i;

      function normalize(term) {
        // Match backend normalization: strip, lowercase, and normalize Unicode to NFC
        return term.trim().toLowerCase().normalize("NFC");
      }

      function isAllowedTerm(term) {
        return ALLOWED_PATTERN.test(term);
      }

      function validateTerm(rawTerm) {
        const normalized = normalize(rawTerm);

        // Check if empty
        if (!normalized) {
          return { valid: false, message: "Escribe una palabra para validar." };
        }

        // Check length (3-25 characters after normalization)
        if (normalized.length < 3 || normalized.length > 25) {
          return {
            valid: false,
            message: "La palabra debe tener entre 3 y 25 caracteres.",
          };
        }

        // Check for unsupported characters
        if (!isAllowedTerm(normalized)) {
          return {
            valid: false,
            message:
              "La palabra contiene caracteres no permitidos. Usa solo letras, acentos y ñ.",
          };
        }

        return { valid: true, normalized };
      }

      function setLoading(loading) {
        isLoading = loading;
        submitBtn.disabled = loading;
        if (loading) {
          resultMessage.textContent = "Validando palabra...";
          resultMessage.className =
            "text-base font-medium text-slate-500 dark:text-slate-400";
          raeLink.classList.add("hidden");
          result.classList.remove("hidden");
        }
      }

      async function ensureSession() {
        const response = await fetch(`${apiBaseUrlValue}/api/session`, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({}),
        });

        if (!response.ok) {
          const payload = await response.json().catch(() => ({}));
          throw new Error(
            payload.detail || "No se pudo iniciar la sesión segura.",
          );
        }
      }

      function showError(message) {
        resultMessage.textContent = message;
        resultMessage.className =
          "text-base font-medium text-rose-700 dark:text-rose-400";
        raeLink.classList.add("hidden");
        result.classList.remove("hidden");
      }

      function renderResult(data) {
        if (!data.is_valid) {
          showError("La IA cree que esta palabra no es válida.");
          return;
        }

        resultMessage.textContent = "La IA cree que esta palabra es válida.";
        resultMessage.className =
          "text-base font-medium text-slate-700 dark:text-slate-200";

        if (data.lemma) {
          raeLink.href = `https://dle.rae.es/${encodeURIComponent(data.lemma)}`;
          raeLink.textContent = `Abrir consulta RAE para ${data.lemma}`;
          raeLink.classList.remove("hidden");
        } else {
          raeLink.classList.add("hidden");
        }

        result.classList.remove("hidden");
      }

      input.addEventListener("input", () => {
        if (!normalize(String(input.value || ""))) {
          result.classList.add("hidden");
        }
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        // Prevent multiple submissions
        if (isLoading) return;

        const rawTerm = String(input.value || "");
        if (!normalize(rawTerm)) {
          result.classList.add("hidden");
          return;
        }

        // Perform all client-side validation
        const validation = validateTerm(rawTerm);
        if (!validation.valid) {
          showError(validation.message);
          return;
        }

        result.classList.add("hidden");
        setLoading(true);

        try {
          await ensureSession();

          const response = await fetch(`${apiBaseUrlValue}/api/validate`, {
            method: "POST",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ term: validation.normalized }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            showError(payload.detail || "No se pudo completar la validacion.");
            return;
          }

          renderResult(payload);
        } catch (error) {
          showError(
            error instanceof Error
              ? error.message
              : "Error temporal al consultar la API.",
          );
        } finally {
          setLoading(false);
        }
      });
    </script>
  </body>
</html>
